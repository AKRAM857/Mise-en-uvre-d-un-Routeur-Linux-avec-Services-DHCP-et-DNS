options {
    directory "/var/cache/bind";
    listen-on port 53 {
        localhost;
        127.0.0.1;
        192.168.10.1;
    };
    allow-query { 
        localhost;
        192.168.10.0/24;
    };
    allow-recursion { 
        localhost;
        192.168.10.0/24;
    };
    listen-on-v6 {none;};
    forwarders {
        8.8.8.8;
        1.1.1.1;
    };
    forward only;
    version "not disclosed";
    dnssec-validation no;

};
